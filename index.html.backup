<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saloni Jat | Professional Portfolio</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar" id="navbar">
        <div class="container">
            <div class="logo">Saloni<span>.dev</span></div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content">
            <h1 class="glitch" data-text="Saloni Jat">Saloni Jat</h1>
            <p class="typing-text">BCA Student | Cyber Security Enthusiast | Java Developer</p>
            <div class="hero-buttons">
                <a href="#contact" class="btn btn-primary">Hire Me</a>
                <a href="#projects" class="btn btn-secondary">View Work</a>
            </div>
            <div class="social-links">
                <a href="#" target="_blank"><i class="fab fa-linkedin"></i></a>
                <a href="#" target="_blank"><i class="fab fa-github"></i></a>
                <a href="#" target="_blank"><i class="fab fa-twitter"></i></a>
                <a href="mailto:salonijat1707@gmail.com"><i class="fas fa-envelope"></i></a>
            </div>
        </div>
        <div class="scroll-down">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2 class="section-title">About <span>Me</span></h2>
            <div class="about-content">
                <div class="about-image">
                    <div class="image-placeholder">
                        <i class="fas fa-user"></i>
                    </div>
                </div>
                <div class="about-text">
                    <h3>Hello! I'm Saloni Jat</h3>
                    <p>I am a passionate BCA student with a strong interest in Cyber Security and Java Development. I love building secure applications and exploring the latest technologies in the field of information security.</p>
                    <p>My journey in tech started with a curiosity about how systems work and how to protect them. Now, I'm constantly learning and implementing new security practices and development techniques.</p>
                    <div class="about-stats">
                        <div class="stat">
                            <h4>5+</h4>
                            <p>Projects Completed</p>
                        </div>
                        <div class="stat">
                            <h4>3+</h4>
                            <p>Years Learning</p>
                        </div>
                        <div class="stat">
                            <h4>10+</h4>
                            <p>Technologies</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="skills">
        <div class="container">
            <h2 class="section-title">My <span>Skills</span></h2>
            <div class="skills-grid">
                <div class="skill-card">
                    <div class="skill-icon"><i class="fab fa-java"></i></div>
                    <h3>Java</h3>
                    <div class="progress-bar">
                        <div class="progress" data-progress="85"></div>
                    </div>
                    <span class="progress-text">85%</span>
                </div>
                <div class="skill-card">
                    <div class="skill-icon"><i class="fab fa-html5"></i></div>
                    <h3>HTML/CSS</h3>
                    <div class="progress-bar">
                        <div class="progress" data-progress="90"></div>
                    </div>
                    <span class="progress-text">90%</span>
                </div>
                <div class="skill-card">
                    <div class="skill-icon"><i class="fab fa-js"></i></div>
                    <h3>JavaScript</h3>
                    <div class="progress-bar">
                        <div class="progress" data-progress="75"></div>
                    </div>
                    <span class="progress-text">75%</span>
                </div>
                <div class="skill-card">
                    <div class="skill-icon"><i class="fas fa-shield-alt"></i></div>
                    <h3>Cyber Security</h3>
                    <div class="progress-bar">
                        <div class="progress" data-progress="70"></div>
                    </div>
                    <span class="progress-text">70%</span>
                </div>
                <div class="skill-card">
                    <div class="skill-icon"><i class="fas fa-network-wired"></i></div>
                    <h3>Networking</h3>
                    <div class="progress-bar">
                        <div class="progress" data-progress="65"></div>
                    </div>
                    <span class="progress-text">65%</span>
                </div>
                <div class="skill-card">
                    <div class="skill-icon"><i class="fas fa-code"></i></div>
                    <h3>OOP Concepts</h3>
                    <div class="progress-bar">
                        <div class="progress" data-progress="80"></div>
                    </div>
                    <span class="progress-text">80%</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="projects">
        <div class="container">
            <h2 class="section-title">My <span>Projects</span></h2>
            <div class="projects-grid">
                <div class="project-card">
                    <div class="project-image">
                        <i class="fas fa-lock"></i>
                    </div>
                    <div class="project-content">
                        <h3>Password Strength Checker</h3>
                        <p>A GUI-based Java application that analyzes password security based on length, special characters, numbers, and case sensitivity.</p>
                        <div class="project-tags">
                            <span>Java</span>
                            <span>Swing</span>
                            <span>Security</span>
                        </div>
                        <a href="#" class="project-link">View Details <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
                <div class="project-card">
                    <div class="project-image">
                        <i class="fas fa-globe"></i>
                    </div>
                    <div class="project-content">
                        <h3>Portfolio Website</h3>
                        <p>A modern, responsive portfolio website with backend integration for contact form and dynamic content management.</p>
                        <div class="project-tags">
                            <span>HTML/CSS</span>
                            <span>JavaScript</span>
                            <span>Node.js</span>
                        </div>
                        <a href="#" class="project-link">View Details <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
                <div class="project-card">
                    <div class="project-image">
                        <i class="fas fa-bug"></i>
                    </div>
                    <div class="project-content">
                        <h3>Network Scanner</h3>
                        <p>A basic network scanning tool to identify active hosts and open ports on a local network for security assessment.</p>
                        <div class="project-tags">
                            <span>Python</span>
                            <span>Networking</span>
                            <span>Security</span>
                        </div>
                        <a href="#" class="project-link">View Details <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <h2 class="section-title">Get In <span>Touch</span></h2>
            <div class="contact-content">
                <div class="contact-info">
                    <div class="info-card">
                        <i class="fas fa-envelope"></i>
                        <h3>Email</h3>
                        <p>salonijat1707@gmail.com</p>
                    </div>
                    <div class="info-card">
                        <i class="fas fa-phone"></i>
                        <h3>Phone</h3>
                        <p>123-456-7890</p>
                    </div>
                    <div class="info-card">
                        <i class="fas fa-map-marker-alt"></i>
                        <h3>Location</h3>
                        <p>India</p>
                    </div>
                </div>
                <form class="contact-form" id="contactForm">
                    <div class="form-group">
                        <input type="text" name="name" placeholder="Your Name" required>
                    </div>
                    <div class="form-group">
                        <input type="email" name="email" placeholder="Your Email" required>
                    </div>
                    <div class="form-group">
                        <input type="text" name="subject" placeholder="Subject" required>
                    </div>
                    <div class="form-group">
                        <textarea name="message" rows="5" placeholder="Your Message" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Send Message</button>
                    <div class="form-message"></div>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Saloni Jat. All Rights Reserved.</p>
            <div class="footer-links">
                <a href="#home">Home</a>
                <a href="#about">About</a>
                <a href="#projects">Projects</a>
                <a href="#contact">Contact</a>
            </div>
        </div>
    </footer>

    <script src="js/script.js"></script>
</body>
</html>
